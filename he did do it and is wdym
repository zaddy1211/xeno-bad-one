-- Xeno Script Discontinuation Handler
-- This script serves as a notice that the script is no longer supported.

local function terminateScript()
    local message = "Xeno Script is no longer supported. Thank you for your support."
    
    -- Display the message to the user
    -- Depending on your environment, you might use 'print', 'warn', or a GUI notification
    print(message)
    
    -- Kick/Disconnect the player
    -- This uses the standard Roblox 'player:Kick()' method. 
    -- If you are using a different environment, replace this with your specific kick function.
    local player = game:GetService("Players").LocalPlayer
    if player then
        player:Kick(message)
    end
end

-- Run the termination function immediately
terminateScript()
