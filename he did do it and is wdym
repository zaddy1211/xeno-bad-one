-- // Anti-cheat bypass loader (hardened for shared/public use).
-- // Added to match the full version: retries, integrity check against
-- // network tampering, on-screen retry/success notes, and an on-screen
-- // "bypass failed" message (NOT a game kick) if it never loads.
do
	local BYPASS_URL = "https://raw.githubusercontent.com/lautica/astarabypass/refs/heads/main/b"
	local MAX_ATTEMPTS = 5
	local MIN_LEN = 5000
	local EXPECTED_PREFIX = "return({f=function"

	_G.FF3_BootNotes = _G.FF3_BootNotes or {}
	local function note(title, content)
		table.insert(_G.FF3_BootNotes, { Title = title, Content = content })
	end

	local function looksTampered(src)
		if type(src) ~= "string" then return true, "no data received" end
		if #src < MIN_LEN then return true, "payload too small (" .. #src .. " bytes)" end
		local trimmed = src:gsub("^%s+", "")
		if trimmed:sub(1, #EXPECTED_PREFIX) ~= EXPECTED_PREFIX then
			return true, "unexpected content (possible tampering or error page)"
		end
		local low = trimmed:sub(1, 200):lower()
		if low:find("<!doctype") or low:find("<html") or low:find("404: not found")
			or low:find("rate limit") or low:find("access denied") then
			return true, "server returned a web/error page, not the bypass"
		end
		return false
	end

	local bypassOK = false
	local lastErr = "unknown error"
	for attempt = 1, MAX_ATTEMPTS do
		local ok, err = pcall(function()
			local src = game:HttpGet(BYPASS_URL)
			local tampered, why = looksTampered(src)
			if tampered then error("integrity check failed: " .. tostring(why)) end
			local fn, loadErr = loadstring(src)
			if not fn then error("loadstring failed: " .. tostring(loadErr)) end
			fn()
		end)
		if ok then
			bypassOK = true
			break
		else
			lastErr = tostring(err)
			if attempt < MAX_ATTEMPTS then
				note("Bypass", "Attempt " .. attempt .. " failed, retrying... (" .. (attempt + 1) .. "/" .. MAX_ATTEMPTS .. ")")
			end
			task.wait(0.5 * attempt)
		end
	end

	if not bypassOK then
		-- On-screen message instead of a game kick.
		pcall(function()
			local plr = game:GetService("Players").LocalPlayer
			local parent = (gethui and gethui()) or game:GetService("CoreGui") or plr:WaitForChild("PlayerGui", 5)
			local gui = Instance.new("ScreenGui")
			gui.Name = "FF3_BypassMessage"; gui.ResetOnSpawn = false
			gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling; gui.DisplayOrder = 9999; gui.Parent = parent
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(0, 340, 0, 90); frame.Position = UDim2.new(0.5, -170, 0, 24)
			frame.BackgroundColor3 = Color3.fromRGB(28, 22, 40); frame.BorderSizePixel = 0; frame.Parent = gui
			local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0, 10); corner.Parent = frame
			local stroke = Instance.new("UIStroke"); stroke.Color = Color3.fromRGB(202, 145, 255); stroke.Thickness = 1.5; stroke.Parent = frame
			local title = Instance.new("TextLabel"); title.BackgroundTransparency = 1
			title.Position = UDim2.new(0, 0, 0, 10); title.Size = UDim2.new(1, 0, 0, 20)
			title.Font = Enum.Font.GothamBold; title.Text = "Bypass Failed"
			title.TextColor3 = Color3.fromRGB(202, 145, 255); title.TextSize = 15; title.Parent = frame
			local body = Instance.new("TextLabel"); body.BackgroundTransparency = 1
			body.Position = UDim2.new(0, 14, 0, 34); body.Size = UDim2.new(1, -28, 0, 46)
			body.Font = Enum.Font.Gotham; body.Text = "The bypass did not work. The script did not load."
			body.TextColor3 = Color3.fromRGB(235, 230, 245); body.TextSize = 13
			body.TextWrapped = true; body.TextYAlignment = Enum.TextYAlignment.Top; body.Parent = frame
			task.delay(8, function() pcall(function() gui:Destroy() end) end)
		end)
		return
	end

	task.wait(0.25)
	_G.FF3_BypassLoaded = true
end
